<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="API Configuration"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="google_api_key"
            android:title="API Key"
            android:summary="Your Google AI API key"
            android:inputType="textPassword"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="google_api_url"
            android:title="API URL"
            android:summary="Google AI API endpoint URL"
            android:defaultValue="https://generativelanguage.googleapis.com/v1beta"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Model Settings"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="google_model"
            android:title="Model"
            android:summary="Select Google AI model to use"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="google_temperature"
            android:title="Temperature"
            android:summary="Controls randomness (0.0 to 1.0)"
            android:defaultValue="0.7"
            android:inputType="numberDecimal"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="google_top_p"
            android:title="Top P"
            android:summary="Controls diversity via nucleus sampling (0.0 to 1.0)"
            android:defaultValue="1.0"
            android:inputType="numberDecimal"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="System Prompt"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="google_system_prompt_enabled"
            android:title="Use System Prompt"
            android:summary="Enable custom system prompt"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="google_system_prompt"
            android:title="System Prompt"
            android:summary="Custom system prompt for all conversations"
            android:defaultValue="You are a helpful AI assistant."
            app:iconSpaceReserved="false" />

    </PreferenceCategory>
</PreferenceScreen>