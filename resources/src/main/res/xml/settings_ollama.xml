<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Server Configuration"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="ollama_api_url"
            android:title="Server URL"
            android:summary="Ollama server address (e.g., http://localhost:11434)"
            android:defaultValue="http://localhost:11434"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Model Settings"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="ollama_model"
            android:title="Model"
            android:summary="Select Ollama model to use"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="ollama_custom_model"
            android:title="Custom Model"
            android:summary="Enter a custom model name if not in the list"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="ollama_temperature"
            android:title="Temperature"
            android:summary="Controls randomness (0.0 to 1.0)"
            android:defaultValue="0.7"
            android:inputType="numberDecimal"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="ollama_top_p"
            android:title="Top P"
            android:summary="Controls diversity via nucleus sampling (0.0 to 1.0)"
            android:defaultValue="1.0"
            android:inputType="numberDecimal"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="System Prompt"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="ollama_system_prompt_enabled"
            android:title="Use System Prompt"
            android:summary="Enable custom system prompt"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="ollama_system_prompt"
            android:title="System Prompt"
            android:summary="Custom system prompt for all conversations"
            android:defaultValue="You are a helpful AI assistant."
            app:iconSpaceReserved="false" />

    </PreferenceCategory>
</PreferenceScreen>
